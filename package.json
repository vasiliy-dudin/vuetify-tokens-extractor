{
  "name": "vuetify-tokens-extractor",
  "version": "0.1.0",
  "private": true,
  "description": "Extracts Vuetify component styles (padding, radius, fonts, colours, sizes, states) from compiled CSS into JSON, one file per component.",
  "type": "module",
  "bin": {
    "vuetify-tokens-extractor": "bin/extract-style-tokens.mjs"
  },
  "exports": {
    ".": "./src/cli.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "extract": "node bin/extract-style-tokens.mjs"
  },
  "dependencies": {
    "postcss": "^8.5.19"
  },
  "peerDependencies": {
    "vuetify": ">=3.0.0"
  }
}
